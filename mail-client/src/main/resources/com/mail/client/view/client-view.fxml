<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mail.client.view.ClientViewController"
      prefWidth="800" prefHeight="600">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Login bar -->
    <HBox fx:id="loginBar" spacing="10" alignment="CENTER_LEFT">
        <Label text="Email:"/>
        <TextField fx:id="emailField" promptText="your@email.com" prefWidth="250"/>
        <Button text="Login" onAction="#onLogin"/>
        <!-- Connection status indicator -->
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="Not connected" style="-fx-text-fill: red;"/>
    </HBox>

    <!-- Main content (hidden until login) -->
    <SplitPane fx:id="mainContent" dividerPositions="0.35" VBox.vgrow="ALWAYS"
               visible="false" managed="false">

        <!-- Left: email list -->
        <VBox spacing="5">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Inbox" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Compose" onAction="#onCompose"/>
                <Button text="Delete" onAction="#onDelete"/>
            </HBox>
            <ListView fx:id="emailListView" VBox.vgrow="ALWAYS"/>
        </VBox>

        <!-- Right: email detail / compose -->
        <VBox fx:id="detailPane" spacing="10">
            <padding>
                <Insets left="10"/>
            </padding>

            <!-- Detail view -->
            <VBox fx:id="detailView" spacing="5" VBox.vgrow="ALWAYS">
                <HBox spacing="5">
                    <Label text="From:" style="-fx-font-weight: bold;"/>
                    <Label fx:id="detailFrom"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="To:" style="-fx-font-weight: bold;"/>
                    <Label fx:id="detailTo"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="Date:" style="-fx-font-weight: bold;"/>
                    <Label fx:id="detailDate"/>
                </HBox>
                <HBox spacing="5">
                    <Label text="Subject:" style="-fx-font-weight: bold;"/>
                    <Label fx:id="detailSubject" style="-fx-font-weight: bold;"/>
                </HBox>
                <Separator/>
                <TextArea fx:id="detailBody" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10">
                    <Button text="Reply" onAction="#onReply"/>
                    <Button text="Reply All" onAction="#onReplyAll"/>
                    <Button text="Forward" onAction="#onForward"/>
                </HBox>
            </VBox>

            <!-- Compose view (hidden by default) -->
            <VBox fx:id="composeView" spacing="5" VBox.vgrow="ALWAYS"
                  visible="false" managed="false">
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="To:" prefWidth="60"/>
                    <TextField fx:id="composeTo" promptText="recipient@email.com, ..." HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Subject:" prefWidth="60"/>
                    <TextField fx:id="composeSubject" HBox.hgrow="ALWAYS"/>
                </HBox>
                <TextArea fx:id="composeBody" wrapText="true" VBox.vgrow="ALWAYS"
                          promptText="Write your message..."/>
                <HBox spacing="10">
                    <Button text="Send" onAction="#onSend"/>
                    <Button text="Cancel" onAction="#onCancelCompose"/>
                </HBox>
            </VBox>
        </VBox>
    </SplitPane>

    <!-- Status bar -->
    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>
</VBox>
